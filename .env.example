# Database connection string for Prisma/Postgres.
DATABASE_URL="postgresql://frozensapphire:frozensapphire@localhost:5432/frozensapphire"

# Redis connection string for BullMQ queues.
REDIS_URL="redis://localhost:6379"

# S3-compatible storage for media uploads.
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="frozensapphire"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio123"

# Application settings.
APP_URL="http://localhost:3000"
LOG_LEVEL="info"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
PORT="3000"
RUN_MIGRATIONS="1"

# E2E test defaults.
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
E2E_ADMIN_EMAIL="admin@frozensapphire.local"
E2E_ADMIN_PASSWORD="ChangeMe123!"
E2E_AUTHOR_ONE_EMAIL="author@frozensapphire.local"
E2E_AUTHOR_TWO_EMAIL="author2@frozensapphire.local"
E2E_AUTHOR_PASSWORD="ChangeMe123!"
